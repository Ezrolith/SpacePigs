rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /scores/{entry} {
      // Anyone can read the leaderboard
      allow read: if true;

      // Anyone can submit a score, but the entry must be valid
      allow create: if
        // Must have exactly these five fields
        request.resource.data.keys().hasAll(['name', 'score', 'wave', 'difficulty', 'ts']) &&
        request.resource.data.keys().hasOnly(['name', 'score', 'wave', 'difficulty', 'ts']) &&

        // name must be a non-empty string, max 20 characters
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 20 &&

        // score must be a non-negative integer within a realistic range
        request.resource.data.score is int &&
        request.resource.data.score >= 0 &&
        request.resource.data.score <= 999999 &&

        // wave must be a positive integer
        request.resource.data.wave is int &&
        request.resource.data.wave >= 1 &&
        request.resource.data.wave <= 999 &&

        // difficulty must be one of the valid options
        request.resource.data.difficulty is string &&
        request.resource.data.difficulty in ['easy', 'normal', 'hard'] &&

        // timestamp must be set by the server
        request.resource.data.ts == request.time;

      // No updates or deletes allowed
      allow update, delete: if false;
    }
  }
}
